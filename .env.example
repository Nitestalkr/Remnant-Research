# Ghostworks site environment variables
# Copy to .env and fill in actual values

# Public site URL (used for canonical links, sitemap, etc.)
PUBLIC_SITE_URL=https://ghostworks.info

# Contact email displayed on contact page
PUBLIC_CONTACT_EMAIL=contact@ghostworks.info

# GitHub research repo link
PUBLIC_GITHUB_REPO=https://github.com/Nitestalkr/Remnant-Research

