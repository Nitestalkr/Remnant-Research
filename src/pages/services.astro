---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const githubRepo = import.meta.env.PUBLIC_GITHUB_REPO ?? 'https://github.com/Nitestalkr/Remnant-Research';

const services = [
  {
    title: 'Cognitive Architecture Design',
    description: 'Custom GNW-based architectures tailored to your domain. We design drive systems with calibrated thresholds, conflict resolution protocols, and boredom-based self-initiation — grounded in the same stability-tested framework that powers our own research deployment.',
    deliverables: ['Drive specification with threshold tables', 'Conflict resolution protocol', 'Boredom and self-initiation model', 'Stability test suite'],
    href: `${githubRepo}/tree/main/gnw`,
  },
  {
    title: 'Research Pipeline Engineering',
    description: 'GRAO-derived research loops that treat experimentation as gradient descent. We build execution trace capture, pattern analysis, proposal generation, and experience store integration — turning ad-hoc research into a measurable, self-improving system.',
    deliverables: ['Execution trace pipeline', 'Pattern analysis and gradient computation', 'Proposal generation framework', 'Experience store with validation gates'],
    href: `${githubRepo}/tree/main/tpg-grao`,
  },
  {
    title: 'Agent System Architecture Review',
    description: 'Independent audit of autonomous agent systems: drive stability, conflict resolution convergence, boredom threshold calibration, memory integrity, and safety veto mechanics. We produce the same formal test battery used on GNW — with written findings and parameter recommendations.',
    deliverables: ['Formal stability test results (5-test battery)', 'Parameter calibration recommendations', 'Safety veto audit', 'Memory integrity verification'],
    href: `${githubRepo}#readme`,
  },
  {
    title: 'Research Publication Support',
    description: 'Translation of operational architectures into reproducible publications. We help research teams go from running code to published specification: full parameter disclosure, cycle data packaging, gradient derivation documentation, and open-source release structuring.',
    deliverables: ['Parameter disclosure documentation', 'Cycle data packaging', 'Gradient derivation write-up', 'Open-source release structure'],
    href: `${githubRepo}/issues`,
  },
];
---

<BaseLayout
  title="Services"
  description="Ghostworks offers cognitive architecture design, research pipeline engineering, agent system auditing, and research publication support."
  canonicalPath="/services"
>
  <Hero
    eyebrow="Services"
    title="From framework to deployment."
    subtitle="The same methodology powering GNW and GRAO — applied to your research or agent system. We work on architecture design, pipeline engineering, system auditing, and publication support."
  />

  <section class="container-content pb-16 animate-fade-up">
    <div class="mb-10 space-y-2">
      <p class="font-mono text-2xs uppercase tracking-wider text-fg-subtle">What We Offer</p>
      <h2 class="text-2xl font-medium tracking-tight sm:text-3xl">Four engagement areas.</h2>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      {
        services.map((s, i) => (
          <div class={`card flex flex-col gap-4 stagger-${i + 1} animate-fade-up`}>
            <div class="space-y-2">
              <h3 class="text-xl font-medium tracking-tight">{s.title}</h3>
              <p class="text-sm leading-relaxed text-fg-muted">{s.description}</p>
            </div>

            <dl class="mt-auto border-t border-border-subtle pt-4">
              <dt class="mb-2 font-mono text-2xs uppercase tracking-wider text-accent">Deliverables</dt>
              {s.deliverables.map((d) => (
                <dd class="border-b border-border-subtle py-1.5 text-sm text-fg-muted last:border-b-0">{d}</dd>
              ))}
            </dl>
          </div>
        ))
      }
    </div>
  </section>

  <section class="container-content pb-16 animate-fade-up stagger-1">
    <div class="surface-glow rounded-lg border border-border bg-bg-subtle p-8 sm:p-10">
      <div class="grid gap-8 sm:grid-cols-[1fr_2fr] sm:gap-12">
        <div class="space-y-2">
          <p class="font-mono text-2xs uppercase tracking-wider text-fg-subtle">Approach</p>
          <h2 class="text-2xl font-medium tracking-tight">How we work.</h2>
        </div>

        <div class="space-y-4 text-fg-muted">
          <p>
            Every engagement starts with the same principle: the architecture must be measurable
            before it can be improved. We calibrate from real cycle data, not design documents.
          </p>
          <p>
            Deliverables include the full parameter set, stability test results, and integration
            guidance — the same specification depth we publish for GNW and GRAO. No black boxes,
            no proprietary lock-in.
          </p>
          <p>
            Engagement structure is scoped per project. A typical architecture review runs 2-4
            weeks. Custom architecture design is 4-8 weeks depending on domain complexity and
            stability requirements.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-content pb-24 animate-fade-up stagger-2">
    <div class="flex flex-wrap items-center gap-3">
      <a href="/contact" class="btn-primary">Discuss a project</a>
      <a href="/research" class="btn-secondary">View the research -></a>
    </div>
  </section>
</BaseLayout>
