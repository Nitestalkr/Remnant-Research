---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const githubRepo = import.meta.env.PUBLIC_GITHUB_REPO ?? 'https://github.com/Nitestalkr/Remnant-Research';
const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL ?? 'contact@ghostworks.info';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Ghostworks - research collaboration, questions, or feedback."
  canonicalPath="/contact"
>
  <Hero
    eyebrow="Contact"
    title="Get in touch."
    subtitle="Questions about the research, collaboration interest, or feedback on the frameworks are all welcome."
  />

  <section class="container-content pb-24 animate-fade-up">
    <div class="grid gap-4 sm:grid-cols-2">
      <a href={`mailto:${contactEmail}`} class="card flex flex-col gap-3 stagger-1 animate-fade-up">
        <div class="flex items-center justify-between">
          <span class="font-mono text-2xs uppercase tracking-wider text-accent">Email</span>
          <span class="text-fg-subtle">-&gt;</span>
        </div>
        <p class="text-lg font-medium">{contactEmail}</p>
        <p class="text-sm text-fg-muted">
          For research questions, collaboration, or anything else.
        </p>
      </a>

      <a href={githubRepo} target="_blank" rel="noopener noreferrer" class="card flex flex-col gap-3 stagger-2 animate-fade-up">
        <div class="flex items-center justify-between">
          <span class="font-mono text-2xs uppercase tracking-wider text-accent">GitHub</span>
          <span class="text-fg-subtle">-&gt;</span>
        </div>
        <p class="text-lg font-medium">Remnant-Research</p>
        <p class="text-sm text-fg-muted">
          Open issues for technical questions or specific framework feedback.
        </p>
      </a>
    </div>

    <!-- TODO: agent team - when backend hosting is enabled, replace mailto with proper contact form here. -->
    <p class="mt-12 max-w-prose text-sm text-fg-subtle">
      A proper contact form will be added once backend hosting is provisioned. For now, email is
      the fastest path.
    </p>
  </section>

  <section class="container-content pb-24 animate-fade-up stagger-1">
    <div class="grid gap-12 sm:grid-cols-[1fr_2fr]">
      <div class="space-y-2">
        <p class="font-mono text-2xs uppercase tracking-wider text-fg-subtle">FAQ</p>
        <h2 class="text-2xl font-medium tracking-tight">Common questions.</h2>
      </div>

      <dl class="space-y-6 text-sm text-fg-muted">
        <div>
          <dt class="mb-1 font-medium text-fg">How quickly do you respond?</dt>
          <dd>Typically within 48 hours. For time-sensitive inquiries, include "URGENT" in the subject line.</dd>
        </div>
        <div>
          <dt class="mb-1 font-medium text-fg">Do you take on contract work?</dt>
          <dd>
            Yes. See the <a href="/services" class="link-accent">Services</a> page for details on
            architecture design, pipeline engineering, and system auditing engagements.
          </dd>
        </div>
        <div>
          <dt class="mb-1 font-medium text-fg">Can I contribute to the research?</dt>
          <dd>
            The research repository is open for issues and discussions. Framework-specific feedback
            is best directed to the relevant GitHub issue tracker.
          </dd>
        </div>
      </dl>
    </div>
  </section>
</BaseLayout>




