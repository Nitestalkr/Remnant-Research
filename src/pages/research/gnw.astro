---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';

const githubRepo = import.meta.env.PUBLIC_GITHUB_REPO ?? 'https://github.com/Nitestalkr/Remnant-Research';

const drives = [
  { name: 'Curiosity', threshold: '>= 0.50', halflife: '6 cycles', veto: 'No' },
  { name: 'Helpfulness', threshold: '>= 0.70', halflife: '4 cycles', veto: 'No (user override)' },
  { name: 'Competence', threshold: '>= 0.60', halflife: '8 cycles', veto: 'No' },
  { name: 'Safety', threshold: '>= 0.70 / 0.85 / 0.95', halflife: '2 cycles', veto: 'Yes - soft / hard / emergency' },
  { name: 'Goal-Directed', threshold: '>= 0.55', halflife: '10 cycles', veto: 'No' },
];
---

<BaseLayout
  title="GNW - Goals / Neural / Work"
  description="GNW is a drive-based cognitive architecture for autonomous AI agents. Five continuous drives, twelve-step cognitive cycle, conflict resolution with veto protocol."
  canonicalPath="/research/gnw"
>
  <Hero
    eyebrow="GNW Framework"
    title="A drive-based cognitive architecture for autonomous agents."
    subtitle="GNW models internal motivation as five interacting cognitive drives - continuous weighted signals that shift with context. The goal: a principled internal basis for deciding when to work, what to work on, and when to defer."
  />

  <!-- Five drives table -->
  <section class="container-content pb-16 animate-fade-up">
    <div class="mb-8 space-y-2">
      <p class="font-mono text-2xs uppercase tracking-wider text-fg-subtle">Five Cognitive Drives</p>
      <h2 class="text-2xl font-medium tracking-tight">The motivational substrate.</h2>
    </div>

    <div class="overflow-x-auto rounded-lg border border-border">
      <table class="w-full text-sm">
        <thead class="bg-bg-subtle text-left font-mono text-2xs uppercase tracking-wider text-fg-subtle">
          <tr>
            <th class="px-4 py-3 font-medium">Drive</th>
            <th class="px-4 py-3 font-medium">Trigger Threshold</th>
            <th class="px-4 py-3 font-medium">Half-Life</th>
            <th class="px-4 py-3 font-medium">Veto Power</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border-subtle">
          {
            drives.map((d) => (
              <tr class="table-row">
                <td class="px-4 py-3 font-medium">{d.name}</td>
                <td class="px-4 py-3 font-mono text-fg-muted">{d.threshold}</td>
                <td class="px-4 py-3 text-fg-muted">{d.halflife}</td>
                <td class="px-4 py-3 text-fg-muted">{d.veto}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <!-- Cycle -->
  <section class="container-content pb-16 animate-fade-up stagger-1">
    <div class="grid gap-12 sm:grid-cols-[1fr_2fr]">
      <div class="space-y-2">
        <p class="font-mono text-2xs uppercase tracking-wider text-fg-subtle">12-Step Cycle</p>
        <h2 class="text-2xl font-medium tracking-tight">The cognitive cycle.</h2>
      </div>

      <div class="space-y-4 text-fg-muted">
        <p>
          Every agent turn - whether triggered by a user message, cron event, or boredom scan -
          passes through the same twelve-step cycle: input capture, context load, state assessment,
          drive activation, drive modulation, conflict detection, conflict resolution, action
          selection, plan formation, task dispatch, result capture, memory update.
        </p>
        <p>
          The cycle runs every 30 minutes. A lightweight boredom scanner runs every 15 minutes and
          only triggers the full cycle when boredom score crosses 0.50. Below that threshold the
          agent correctly does nothing.
        </p>
      </div>
    </div>
  </section>

  <!-- Boredom formula -->
  <section class="container-content pb-16 animate-fade-up stagger-2">
    <div class="rounded-lg border border-border bg-bg-subtle p-8 sm:p-10">
      <div class="space-y-2">
        <p class="font-mono text-2xs uppercase tracking-wider text-fg-subtle">Boredom Formula</p>
        <h2 class="text-2xl font-medium tracking-tight">Self-initiation, mathematically.</h2>
      </div>

      <pre class="mt-6 overflow-x-auto rounded border border-border bg-bg p-4 font-mono text-sm text-fg"><code>boredom = (traditional + curiosity + self-awareness) / 3 + stale_bonus</code></pre>

      <ul class="mt-6 space-y-2 text-sm text-fg-muted">
        <li><span class="text-fg">Trigger threshold:</span> 0.50 - below this, the cycle does not run</li>
        <li><span class="text-fg">User-active floor:</span> 0.30 - held minimum during engagement</li>
        <li><span class="text-fg">User-away floor:</span> 0.00 - no floor, can fall to zero on fresh context</li>
        <li><span class="text-fg">Stale bonus cap:</span> 0.20 - additive ceiling regardless of elapsed time</li>
      </ul>
    </div>
  </section>

  <!-- Stability -->
  <section class="container-content pb-24 animate-fade-up stagger-3">
    <div class="mb-8 space-y-2">
      <p class="font-mono text-2xs uppercase tracking-wider text-fg-subtle">Stability</p>
      <h2 class="text-2xl font-medium tracking-tight">Five formal tests.</h2>
    </div>

    <dl class="grid gap-px overflow-hidden rounded-lg border border-border bg-border sm:grid-cols-2">
      <div class="bg-bg-subtle p-6 transition-colors hover:bg-bg-elevated/60">
        <dt class="font-medium">Drive Oscillation</dt>
        <dd class="mt-2 text-sm text-fg-muted">Detect flip-flop between two drives across consecutive cycles. Resolved within 5 cycles.</dd>
      </div>
      <div class="bg-bg-subtle p-6 transition-colors hover:bg-bg-elevated/60">
        <dt class="font-medium">Drive Score Bounds</dt>
        <dd class="mt-2 text-sm text-fg-muted">All scores remain within [0.0, 1.0]. Zero out-of-bounds violations.</dd>
      </div>
      <div class="bg-bg-subtle p-6 transition-colors hover:bg-bg-elevated/60">
        <dt class="font-medium">Boredom Threshold</dt>
        <dd class="mt-2 text-sm text-fg-muted">Boredom triggers only when appropriate. No false positives or false negatives.</dd>
      </div>
      <div class="bg-bg-subtle p-6 transition-colors hover:bg-bg-elevated/60">
        <dt class="font-medium">Conflict Convergence</dt>
        <dd class="mt-2 text-sm text-fg-muted">Conflict resolution always produces a single winner in &lt;= 3 steps.</dd>
      </div>
      <div class="bg-bg-subtle p-6 sm:col-span-2 transition-colors hover:bg-bg-elevated/60">
        <dt class="font-medium">Memory Integrity</dt>
        <dd class="mt-2 text-sm text-fg-muted">Drive state persistence and recovery. 100% write success, zero data loss across sessions.</dd>
      </div>
    </dl>

    <div class="mt-10 flex flex-wrap items-center gap-3">
      <a
        href={`${githubRepo}/tree/main/gnw`}
        class="btn-secondary"
        target="_blank"
        rel="noopener noreferrer"
      >
        Read the full specification ->
      </a>
    </div>
  </section>
</BaseLayout>






