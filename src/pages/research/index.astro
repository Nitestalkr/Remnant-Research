---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ResearchCard from '../../components/ResearchCard.astro';

const githubRepo = import.meta.env.PUBLIC_GITHUB_REPO ?? 'https://github.com/Nitestalkr/Remnant-Research';
---

<BaseLayout
  title="Research"
  description="The Ghostworks research program - GNW cognitive architecture and GRAO gradient-driven research optimization."
  canonicalPath="/research"
>
  <Hero
    eyebrow="Research"
    title="The Ghostworks research program."
    subtitle="Two interconnected frameworks bridging cognitive science theory and operational AI agent deployment. Documented openly, with parameter values, stability tests, and real cycle data."
  />

  <section class="container-content pb-16 animate-fade-up">
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="stagger-1 animate-fade-up">
        <ResearchCard
          tag="GNW"
          title="Goals / Neural / Work"
          description="A drive-based cognitive architecture giving agents principled internal motivation: when to work, what to work on, and when to stop."
          href="/research/gnw"
        />
      </div>
      <div class="stagger-2 animate-fade-up">
        <ResearchCard
          tag="TPG / GRAO"
          title="Gradient-Driven Research Optimization"
          description="A self-improving research loop treating research direction as gradient descent over execution traces."
          href="/research/grao"
        />
      </div>
    </div>
  </section>

  <section class="container-content pb-24 animate-fade-up stagger-1">
    <div class="surface-glow rounded-lg border border-border bg-bg-subtle p-8 sm:p-10">
      <div class="grid gap-12 sm:grid-cols-[1fr_2fr]">
        <div class="space-y-2">
          <p class="font-mono text-2xs uppercase tracking-wider text-fg-subtle">Philosophy</p>
          <h2 class="text-2xl font-medium tracking-tight">Why we publish openly.</h2>
        </div>

        <div class="space-y-4 text-fg-muted">
          <p>
            Cognitive architectures like GNWT, ACT-R, and SOAR have existed for decades, but most
            remain descriptive rather than operational. The translation gap between theory and
            running code is where most work stops.
          </p>
          <p>
            Ghostworks closes that gap publicly: full parameter values, calibrated thresholds,
            stability tests, and live cycle data from a system actually running. Not a paper. Not a
            diagram. A working architecture with reproducible measurements.
          </p>
          <p>
            The full research repository, including pseudocode, experiment records, and live
            gradient computation, is available on
            <a href={githubRepo} class="link-accent" target="_blank" rel="noopener noreferrer">GitHub -&gt;</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>




