---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';

const githubRepo = import.meta.env.PUBLIC_GITHUB_REPO ?? 'https://github.com/Nitestalkr/Remnant-Research';

const progression = [
  { round: 13, date: '2026-04-25', success: '47.4%', note: 'Early stabilization' },
  { round: 20, date: '2026-04-26', success: '65.5%', note: 'Upward trend established' },
  { round: 31, date: '2026-04-27', success: '93.1%', note: 'Peak - 7 experiences, 7 clusters' },
  { round: 33, date: '2026-04-30', success: '89.0%', note: '33 consecutive reinforcement rounds' },
  { round: 38, date: '2026-04-29', success: '83.3%', note: 'Trace quality stabilizing' },
  { round: 39, date: '2026-05-04', success: '92.7%', note: 'Saturation detected' },
];
---

<BaseLayout
  title="TPG/GRAO - Gradient-Driven Research Optimization"
  description="GRAO treats research direction as gradient descent over execution traces. Self-improving research loop with proposal generation, experience store, and policy saturation detection."
  canonicalPath="/research/grao"
>
  <Hero
    eyebrow="TPG / GRAO"
    title="Research direction as gradient descent."
    subtitle="GRAO turns execution traces into directional signals. Pattern analysis produces gradients; gradients generate proposals; validated proposals enter the experience store. The next cycle starts with richer data than the last."
  />

  <!-- Pipeline -->
  <section class="container-content pb-16 animate-fade-up">
    <div class="mb-8 space-y-2">
      <p class="font-mono text-2xs uppercase tracking-wider text-fg-subtle">Pipeline</p>
      <h2 class="text-2xl font-medium tracking-tight">From traces to proposals.</h2>
    </div>

    <ol class="grid gap-3 sm:grid-cols-2">
      <li class="card space-y-2 animate-fade-up stagger-1">
        <p class="font-mono text-2xs uppercase tracking-wider text-accent">01 / Collect</p>
        <p class="text-sm text-fg-muted">
          <span class="text-fg">trace-collector.js</span> normalizes execution records from four
          signal sources: agent, research, stability, experience.
        </p>
      </li>
      <li class="card space-y-2 animate-fade-up stagger-2">
        <p class="font-mono text-2xs uppercase tracking-wider text-accent">02 / Derive</p>
        <p class="text-sm text-fg-muted">
          <span class="text-fg">gradient-deriver.js</span> clusters traces by signal type, computes
          pattern strength, applies temporal adjustment, classifies the gradient.
        </p>
      </li>
      <li class="card space-y-2 animate-fade-up stagger-3">
        <p class="font-mono text-2xs uppercase tracking-wider text-accent">03 / Propose</p>
        <p class="text-sm text-fg-muted">
          <span class="text-fg">proposal-generator.js</span> filters gradients above threshold,
          applies novelty and confidence checks, emits actionable proposals.
        </p>
      </li>
      <li class="card space-y-2 animate-fade-up stagger-3">
        <p class="font-mono text-2xs uppercase tracking-wider text-accent">04 / Analyze</p>
        <p class="text-sm text-fg-muted">
          <span class="text-fg">grao-retriever.js</span> aggregates loop history, tracks trends,
          detects policy saturation, generates cycle reports.
        </p>
      </li>
    </ol>
  </section>

  <!-- Formula -->
  <section class="container-content pb-16 animate-fade-up stagger-1">
    <div class="rounded-lg border border-border bg-bg-subtle p-8 sm:p-10">
      <div class="space-y-2">
        <p class="font-mono text-2xs uppercase tracking-wider text-fg-subtle">Gradient Formula</p>
        <h2 class="text-2xl font-medium tracking-tight">How direction is computed.</h2>
      </div>

      <pre class="mt-6 overflow-x-auto rounded border border-border bg-bg p-4 font-mono text-sm text-fg"><code>gradient_score = (impact x frequency x persistence x consistency) / normalization</code></pre>

      <dl class="mt-6 grid gap-4 sm:grid-cols-2">
        <div>
          <dt class="font-medium">Impact</dt>
          <dd class="text-sm text-fg-muted">Average outcome magnitude per pattern (0.0-1.0)</dd>
        </div>
        <div>
          <dt class="font-medium">Frequency</dt>
          <dd class="text-sm text-fg-muted">Occurrence rate within the analysis window</dd>
        </div>
        <div>
          <dt class="font-medium">Persistence</dt>
          <dd class="text-sm text-fg-muted">How long the pattern has remained stable</dd>
        </div>
        <div>
          <dt class="font-medium">Consistency</dt>
          <dd class="text-sm text-fg-muted">Inverse of outcome variance - reliability of effect</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Live data -->
  <section class="container-content pb-16 animate-fade-up stagger-2">
    <div class="mb-8 space-y-2">
      <p class="font-mono text-2xs uppercase tracking-wider text-fg-subtle">Live Data</p>
      <h2 class="text-2xl font-medium tracking-tight">Round-by-round progression.</h2>
    </div>

    <div class="overflow-x-auto rounded-lg border border-border">
      <table class="w-full text-sm">
        <thead class="bg-bg-subtle text-left font-mono text-2xs uppercase tracking-wider text-fg-subtle">
          <tr>
            <th class="px-4 py-3 font-medium">Round</th>
            <th class="px-4 py-3 font-medium">Date</th>
            <th class="px-4 py-3 font-medium">Success Ratio</th>
            <th class="px-4 py-3 font-medium">Notes</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border-subtle">
          {
            progression.map((r) => (
              <tr class="table-row">
                <td class="px-4 py-3 font-mono text-accent">{r.round}</td>
                <td class="px-4 py-3 font-mono text-fg-muted">{r.date}</td>
                <td class="px-4 py-3 font-medium">{r.success}</td>
                <td class="px-4 py-3 text-fg-muted">{r.note}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p class="mt-4 max-w-prose text-xs text-fg-subtle">
      Round numbers reflect loop iteration sequence, not strict calendar order - round 33 was
      executed after round 38 due to a scheduling gap.
    </p>
  </section>

  <!-- Saturation -->
  <section class="container-content pb-24 animate-fade-up stagger-3">
    <div class="grid gap-12 sm:grid-cols-[1fr_2fr]">
      <div class="space-y-2">
        <p class="font-mono text-2xs uppercase tracking-wider text-fg-subtle">Current State</p>
        <h2 class="text-2xl font-medium tracking-tight">Policy saturation.</h2>
      </div>

      <div class="space-y-4 text-fg-muted">
        <p>
          After 20 consecutive reinforcement rounds with the success ratio plateauing near 93%, the
          system has detected its own saturation: all strong patterns are codified, no new
          optimization areas are being explored.
        </p>
        <p>
          The next phase shifts from reinforcement to exploration - generating gradients toward
          unexplored TPG paths, investigating the ten persistent failure gradients present since
          round 13, and expanding the experience cluster for cross-cluster pattern discovery.
        </p>
      </div>
    </div>

    <div class="mt-10 flex flex-wrap items-center gap-3">
      <a
        href={`${githubRepo}/tree/main/tpg-grao`}
        class="btn-secondary"
        target="_blank"
        rel="noopener noreferrer"
      >
        Read the full specification ->
      </a>
    </div>
  </section>
</BaseLayout>






